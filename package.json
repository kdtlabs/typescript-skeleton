{
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "NODE_ENV=development node bin/run.js",
        "start": "NODE_ENV=production node bin/run.js",
        "test": "vitest run",
        "coverage": "vitest run --coverage",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "typecheck": "tsc --noEmit",
        "up": "ncu -i --format group",
        "preinstall": "only-allow pnpm && ([ -d .git ] && simple-git-hooks || true)"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@hono/node-server": "^2.0.2",
        "@kdtlabs/logger": "^0.0.3",
        "@kdtlabs/utils": "^0.0.16",
        "better-sqlite3": "^12.9.0",
        "colorette": "^2.0.20",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "0.8.3",
        "glob": "^13.0.6",
        "hono": "^4.12.18",
        "json5": "^2.2.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.0",
        "@commitlint/config-conventional": "^21.0.0",
        "@kdtlabs/eslint-config": "^0.0.6",
        "@swc-node/register": "^1.11.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^25.6.2",
        "@vitest/coverage-v8": "^4.1.6",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.3.0",
        "lint-staged": "^17.0.4",
        "npm-check-updates": "^22.1.1",
        "only-allow": "^1.2.2",
        "simple-git-hooks": "^2.13.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.6"
    },
    "simple-git-hooks": {
        "commit-msg": "npx --no -- commitlint --edit ${1}",
        "pre-commit": "pnpm exec lint-staged && pnpm typecheck"
    },
    "lint-staged": {
        "*": "pnpm lint:fix"
    },
    "commitlint": {
        "extends": "@commitlint/config-conventional"
    }
}
